{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/zhanhuiinhk/world-electronic-components/schema/component.schema.json",
  "title": "ElectronicComponent",
  "description": "单个元器件/部件/组件记录的数据格式规范",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "part_number": {
      "type": "string",
      "minLength": 1,
      "description": "厂家官方型号（建议大写，不含多余空格）"
    },
    "manufacturer": {
      "type": "string",
      "minLength": 1,
      "description": "制造厂商官方名称"
    },
    "manufacturer_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "description": "对应 manufacturers/ 下文件的 id（slug）"
    },
    "product_class": {
      "type": "string",
      "enum": ["component", "part", "module"],
      "description": "粒度：component=元器件, part=部件, module=组件/模组"
    },
    "category": {
      "type": "string",
      "description": "一级分类英文名，与 taxonomy 中 name_en 一致"
    },
    "category_slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "description": "一级分类 slug"
    },
    "sub_category": {
      "type": "string",
      "description": "二级分类英文名"
    },
    "sub_category_slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "description": "二级分类 slug"
    },
    "package": {
      "type": "string",
      "description": "封装形式，如 SOIC-8、QFN-48、0402"
    },
    "origin": {
      "type": "string",
      "description": "产地/原产国或地区"
    },
    "datasheet_url": {
      "type": "string",
      "format": "uri",
      "description": "官方 datasheet 链接"
    },
    "description": {
      "type": "string",
      "description": "简短产品描述"
    },
    "status": {
      "type": "string",
      "enum": ["active", "nrnd", "obsolete", "preview"],
      "default": "active",
      "description": "生命周期状态"
    },
    "attributes": {
      "type": "object",
      "description": "弹性技术参数区",
      "additionalProperties": true
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "检索标签"
    },
    "updated_at": {
      "type": "string",
      "format": "date",
      "description": "本条记录最后更新日期 YYYY-MM-DD"
    }
  },
  "required": [
    "part_number",
    "manufacturer",
    "category",
    "category_slug",
    "sub_category",
    "sub_category_slug",
    "datasheet_url"
  ]
}
