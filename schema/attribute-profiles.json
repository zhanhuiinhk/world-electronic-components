{
  "$schema_note": "品类专用 attributes 字段表。key = sub_category_slug。required 为校验必填；recommended 为推荐；fields 定义类型与单位。",
  "version": "1.0.0",
  "_default": {
    "name_en": "Default",
    "name_zh": "默认（无专用表）",
    "required": [],
    "recommended": [],
    "fields": {}
  },
  "resistors": {
    "name_en": "Resistors",
    "name_zh": "电阻",
    "required": ["resistance_ohm"],
    "recommended": ["tolerance_percent", "power_w", "composition"],
    "fields": {
      "resistance_ohm": { "type": "number", "unit": "Ω", "description_en": "Resistance", "description_zh": "阻值" },
      "tolerance_percent": { "type": "number", "unit": "%", "description_en": "Tolerance", "description_zh": "精度" },
      "power_w": { "type": "number", "unit": "W", "description_en": "Power rating", "description_zh": "额定功率" },
      "temperature_coefficient_ppm": { "type": "number", "unit": "ppm/°C", "description_en": "TCR", "description_zh": "温度系数" },
      "composition": { "type": "string", "description_en": "e.g. thick film, metal film", "description_zh": "材质，如厚膜/金属膜" },
      "max_voltage_v": { "type": "number", "unit": "V", "description_zh": "最大工作电压" }
    }
  },
  "potentiometers-trimmers": {
    "name_zh": "电位器与微调",
    "required": ["resistance_ohm"],
    "recommended": ["tolerance_percent", "power_w", "taper"],
    "fields": {
      "resistance_ohm": { "type": "number", "unit": "Ω" },
      "tolerance_percent": { "type": "number", "unit": "%" },
      "power_w": { "type": "number", "unit": "W" },
      "taper": { "type": "string", "description_zh": "阻值变化特性 linear/log" }
    }
  },
  "capacitors": {
    "name_zh": "电容",
    "required": ["capacitance_uf"],
    "recommended": ["voltage_v", "dielectric", "tolerance_percent"],
    "fields": {
      "capacitance_uf": { "type": "number", "unit": "µF", "description_zh": "电容量（微法）" },
      "voltage_v": { "type": "number", "unit": "V", "description_zh": "耐压" },
      "dielectric": { "type": "string", "description_zh": "介质，如 X7R, C0G, electrolytic" },
      "tolerance_percent": { "type": "number", "unit": "%" },
      "esr_ohm": { "type": "number", "unit": "Ω" },
      "temperature_range_c": { "type": "string", "description_zh": "如 -55 to +125" }
    }
  },
  "inductors-coils-chokes": {
    "name_zh": "电感",
    "required": ["inductance_uh"],
    "recommended": ["current_a", "dcr_ohm", "tolerance_percent"],
    "fields": {
      "inductance_uh": { "type": "number", "unit": "µH" },
      "current_a": { "type": "number", "unit": "A" },
      "dcr_ohm": { "type": "number", "unit": "Ω" },
      "tolerance_percent": { "type": "number", "unit": "%" },
      "shielded": { "type": "boolean" }
    }
  },
  "crystals-oscillators": {
    "name_zh": "晶振与振荡器",
    "required": ["frequency_hz"],
    "recommended": ["frequency_stability_ppm", "load_capacitance_pf"],
    "fields": {
      "frequency_hz": { "type": "number", "unit": "Hz" },
      "frequency_stability_ppm": { "type": "number", "unit": "ppm" },
      "load_capacitance_pf": { "type": "number", "unit": "pF" },
      "output_type": { "type": "string", "description_zh": "如 CMOS, clipped sine" }
    }
  },
  "microcontrollers": {
    "name_zh": "微控制器",
    "required": ["core"],
    "recommended": ["flash_kb", "ram_kb", "clock_mhz", "gpio_count", "package_pins"],
    "fields": {
      "core": { "type": "string", "description_zh": "如 ARM Cortex-M3" },
      "flash_kb": { "type": "number", "unit": "KB" },
      "ram_kb": { "type": "number", "unit": "KB" },
      "clock_mhz": { "type": "number", "unit": "MHz" },
      "gpio_count": { "type": "number" },
      "package_pins": { "type": "number" },
      "adc_bits": { "type": "number" },
      "operating_voltage_v": { "type": "string" }
    }
  },
  "memory": {
    "name_zh": "存储器",
    "required": ["density_bits", "memory_type"],
    "recommended": ["interface", "voltage_v"],
    "fields": {
      "density_bits": { "type": "number", "description_zh": "容量（bit）" },
      "memory_type": { "type": "string", "description_zh": "如 NOR Flash, DDR4, EEPROM" },
      "interface": { "type": "string" },
      "voltage_v": { "type": "number", "unit": "V" },
      "speed_mhz": { "type": "number", "unit": "MHz" }
    }
  },
  "analog-ics": {
    "name_zh": "模拟 IC",
    "required": [],
    "recommended": ["function", "supply_voltage_min_v", "supply_voltage_max_v"],
    "fields": {
      "function": { "type": "string", "description_zh": "功能，如 op-amp, timer, comparator" },
