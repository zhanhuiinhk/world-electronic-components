    "fields": {
      "frequency_min_mhz": { "type": "number", "unit": "MHz" },
      "frequency_max_mhz": { "type": "number", "unit": "MHz" },
      "gain_db": { "type": "number", "unit": "dB" },
      "p1db_dbm": { "type": "number", "unit": "dBm" },
      "noise_figure_db": { "type": "number", "unit": "dB" },
      "supply_voltage_v": { "type": "number", "unit": "V" }
    }
  },
  "leds-indicators": {
    "name_zh": "LED",
    "required": ["color"],
    "recommended": ["forward_voltage_v", "forward_current_ma", "wavelength_nm"],
    "fields": {
      "color": { "type": "string" },
      "forward_voltage_v": { "type": "number", "unit": "V" },
      "forward_current_ma": { "type": "number", "unit": "mA" },
      "wavelength_nm": { "type": "number", "unit": "nm" },
      "luminous_intensity_mcd": { "type": "number", "unit": "mcd" }
    }
  },
  "board-to-board": {
    "name_zh": "板对板连接器",
    "required": ["pitch_mm", "positions"],
    "recommended": ["rows", "mating_height_mm", "current_a"],
    "fields": {
      "pitch_mm": { "type": "number", "unit": "mm" },
