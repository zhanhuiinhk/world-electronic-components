    "name_zh": "电源管理 IC",
    "required": ["topology"],
    "recommended": ["vin_min_v", "vin_max_v", "vout_v", "iout_a"],
    "fields": {
      "topology": { "type": "string", "description_zh": "如 buck, boost, LDO" },
      "vin_min_v": { "type": "number", "unit": "V" },
      "vin_max_v": { "type": "number", "unit": "V" },
      "vout_v": { "type": "number", "unit": "V" },
      "iout_a": { "type": "number", "unit": "A" }
    }
  },
  "discrete-transistors": {
    "name_zh": "晶体管",
    "required": ["transistor_type"],
    "recommended": ["vds_v", "id_a", "rds_on_ohm"],
    "fields": {
      "transistor_type": { "type": "string", "description_zh": "MOSFET/BJT/IGBT 等" },
      "vds_v": { "type": "number", "unit": "V" },
      "id_a": { "type": "number", "unit": "A" },
      "rds_on_ohm": { "type": "number", "unit": "Ω" },
      "polarity": { "type": "string" }
    }
  },
  "discrete-diodes-rectifiers": {
    "name_zh": "二极管与整流器",
    "required": ["diode_type"],
    "recommended": ["vr_v", "if_a", "vf_v"],
    "fields": {
      "diode_type": { "type": "string" },
      "vr_v": { "type": "number", "unit": "V" },
      "if_a": { "type": "number", "unit": "A" },
      "vf_v": { "type": "number", "unit": "V" }
    }
  },
  "temperature-sensors": {
    "name_zh": "温度传感器",
    "required": ["sensor_type"],
    "recommended": ["range_min_c", "range_max_c", "accuracy_c", "interface"],
    "fields": {
