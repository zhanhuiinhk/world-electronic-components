      "range_max_c": { "type": "number", "unit": "°C" },
      "accuracy_c": { "type": "number", "unit": "°C" },
      "interface": { "type": "string" }
    }
  },
  "wireless-modules": {
    "name_zh": "无线模组",
    "required": ["protocols"],
    "recommended": ["frequency_mhz", "max_data_rate_kbps", "tx_power_dbm"],
    "fields": {
      "protocols": { "type": "string", "description_zh": "如 Wi-Fi, BLE, LoRa, LTE" },
      "frequency_mhz": { "type": "number", "unit": "MHz" },
      "max_data_rate_kbps": { "type": "number", "unit": "kbps" },
      "tx_power_dbm": { "type": "number", "unit": "dBm" },
      "antenna": { "type": "string" }
    }
  },
